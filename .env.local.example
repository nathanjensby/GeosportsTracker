# Copy to .env.local and fill in to switch the dashboard from mock data to
# live data read from the Google Sheet sync_geosports.py populates.
# Leave GEOSPORTS_DATA_SOURCE unset (or anything other than "sheets") to keep
# using mock data.

GEOSPORTS_DATA_SOURCE=sheets

# The spreadsheet ID from its URL — see SHEET_ID in sync_geosports.py.
GEOSPORTS_SHEET_ID=your-google-sheet-id

# Optional — defaults shown below.
GEOSPORTS_WORKSHEET_NAME=RawData

# Google service account credentials — pick ONE:
# - Local dev: path to the downloaded key file (default shown below).
# - Deployed environments (e.g. Vercel): there's no key file on disk, so set
#   GEOSPORTS_SERVICE_ACCOUNT_KEY_BASE64 instead, to the key file's JSON
#   contents base64-encoded (`base64 -i service-account.json`). It takes
#   priority over the path when both are set.
GEOSPORTS_SERVICE_ACCOUNT_KEY_PATH=service-account.json
GEOSPORTS_SERVICE_ACCOUNT_KEY_BASE64=
